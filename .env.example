# ============================================================
# Process Cloner v1.0 — Configuração
# Copie este arquivo para .env e ajuste conforme necessário
# ============================================================

# ── Limites de tamanho ──
MAX_FILE_SIZE_MB=30
MAX_IMAGE_SIZE_MB=5
REQUEST_TIMEOUT=10

# ── Saída ──
OUTPUT_DIR=output

# ── Ferramentas externas (Node.js) ──
# Instale com: npm install -g prettier lightningcss purgecss
PRETTIER_BIN=prettier
LIGHTNINGCSS_BIN=lightningcss
PURGECSS_BIN=purgecss
NODE_BIN=node

# ── Comportamento do pipeline ──
BUNDLE_SCRIPTS=true       # Agrupa scripts inline em scripts/main.js
USE_PRETTIER=true         # Formata HTML/CSS com Prettier
USE_LIGHTNINGCSS=true     # Otimiza CSS com LightningCSS
USE_PURGECSS=true         # Remove CSS não utilizado
USE_TAILWIND=false        # Injeta Tailwind CDN (opcional)
MINIFY_CSS=false          # Minifica CSS (true = produção, false = legível)

# ── LightningCSS — browsers alvo ──
LIGHTNINGCSS_TARGETS=>= 0.5%

# ── URL base (alternativa ao argumento CLI) ──
# BASE_URL=https://exemplo.com
